# Prisma Database URL
# SQLite를 사용할 경우 로컬 파일 경로 지정, 실제 배포 시에는 PostgreSQL, MySQL 등의 프로덕션 DB URL 권장
DATABASE_URL="file:./dev.db"

# NextAuth Configuration
# 배포할 서버의 실제 도메인 주소로 변경 필수 (예: https://attendance.example.com)
NEXTAUTH_URL="http://localhost:3000"
# 무작위의 긴 문자열 (JWT 암호화에 사용됨), $ openssl rand -base64 32 명령어로 생성 권장
NEXTAUTH_SECRET="my_super_secret_key_123"

# Google OAuth Credentials (선택사항, 구글 로그인을 사용하는 경우)
# Google Cloud Console에서 생성한 클라이언트 ID와 Secret 입력
GOOGLE_CLIENT_ID="your_google_client_id_here"
GOOGLE_CLIENT_SECRET="your_google_client_secret_here"
